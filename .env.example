# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Clé API Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse d'expédition vérifiée dans Resend (ex: contact@votre-domaine.com)
RESEND_FROM=contact@votre-domaine.com

# Email de réception des audits et copies PDF (adresse Arielle)
CONTACT_EMAIL=arielle.de.maistre@gmail.com

# ─── Site URL (pour lien RDV dans les emails clients) ─────────────────────────
# URL publique Railway (ex: https://naturopathie-arielle.railway.app)
SITE_URL=https://naturopathie-arielle.railway.app

# ─── Prisma / PostgreSQL (optionnel — plugin Railway PostgreSQL) ──────────────
# Sans DATABASE_URL : le CRM utilise le fichier JSON local (data/audits.json)
# Format Railway : postgresql://user:password@host.railway.internal:5432/railway?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Port (automatique sur Railway) ──────────────────────────────────────────
PORT=3000
